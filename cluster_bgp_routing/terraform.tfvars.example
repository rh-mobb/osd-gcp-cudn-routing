# OCM offline token. Prefer OSDGOOGLE_TOKEN env var for local dev:
# export OSDGOOGLE_TOKEN="your-token"
#ocm_token = ""

# GCP project ID for the cluster (required). Set via TF_VAR_gcp_project_id or uncomment:
#gcp_project_id = "my-gcp-project"

# Name of the OSD cluster (must match terraform/wif_config cluster_name). Set via TF_VAR_cluster_name or uncomment:
#cluster_name = "my-bgp-cluster"

# Remote Terraform state (recommended outside a single-user lab): see ../docs/terraform-backend-gcs.md
# and backend.tf.example in this directory (copy to backend.tf, terraform init -migrate-state).

# OpenShift version (x.y.z)
openshift_version = "4.21.3"

# Cluster admin password. Omit or leave empty to auto-generate.
#admin_password = ""

# GCP region
gcp_region = "us-central1"

# Bare metal machine type for worker nodes
# compute_machine_type = "c3-standard-192-metal"

# Number of worker nodes
# compute_nodes = 3

# Single zone for bare metal (machine type must exist in zone)
# availability_zone = "us-central1-a"

# CUDN CIDR advertised via BGP
# cudn_cidr = "10.100.0.0/16"

# Worker subnet → CUDN firewall: all | e2etest (default, icmp + tcp/80) | none
# worker_subnet_to_cudn_firewall_mode = "e2etest"

# Optional: network tags on router workers to scope worker→CUDN + BGP:179 rules (empty = all instances)
# routing_worker_target_tags = ["my-cluster-bgp-router"]

# BGP / NCC / Cloud Router. Leave false for the first apply; set true after workers exist.
# enable_bgp_routing = false

# Cloud Router and FRR ASNs (private ASNs; align with configure-routing.sh defaults)
# cloud_router_asn = 64512
# frr_asn = 65003

# Cloud Router interface IPs in the worker subnet (optional). If null, derived from subnet CIDR + offset.
# router_interface_private_ips = null
# bgp_interface_host_offset = 230

# Reserve interface IPs with google_compute_address (default true). Set false for some brownfield upgrades.
# reserve_cloud_router_interface_ips = true

# NCC router appliance spoke
# ncc_spoke_site_to_site_data_transfer = false

# Optional echo VM (requires enable_bgp_routing=true)
# enable_echo_client_vm = false
# echo_client_vm_zone = null
# echo_client_vm_port = 8080
# echo_client_vm_machine_type = "e2-medium"

# Enable PSC for private cluster
# enable_psc = false

# GCP authentication: use Application Default Credentials
# gcloud auth application-default login

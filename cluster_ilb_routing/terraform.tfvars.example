# OCM offline token. Prefer OSDGOOGLE_TOKEN env var for local dev:
# export OSDGOOGLE_TOKEN="your-token"
#ocm_token = ""

# GCP project ID for the cluster (required). Set via TF_VAR_gcp_project_id or uncomment:
#gcp_project_id = "my-gcp-project"

# Name of the OSD cluster (must match terraform/wif_config cluster_name). Set via TF_VAR_cluster_name or uncomment:
#cluster_name = "my-ilb-cluster"

# Remote Terraform state: see ../docs/terraform-backend-gcs.md and backend.tf.example in this directory.

# OpenShift version (x.y.z)
openshift_version = "4.21.3"

# Cluster admin password. Omit or leave empty to auto-generate.
#admin_password = ""

# GCP region
gcp_region = "us-central1"

# Default OSD worker pool machine type (OCM catalog)
# compute_machine_type = "n2-standard-4"

# Number of worker nodes
# compute_nodes = 3

# Single zone for default worker pool (machine type must exist in zone)
# availability_zone = "us-central1-a"

# CUDN CIDR to route through the ILB for direct pod/VM connectivity
# cudn_cidr = "10.100.0.0/16"

# Worker subnet → CUDN firewall: all | e2etest (default, icmp + tcp/80) | none
# worker_subnet_to_cudn_firewall_mode = "e2etest"

# Optional: network tags on ILB backend workers to scope worker→CUDN rule (empty = all instances)
# routing_worker_target_tags = ["my-cluster-ilb-backend"]

# ILB routing to workers (CUDN CIDR via internal NLB). Leave false for the first
# apply (cluster + VPC only). Set true for the second apply after workers exist.
# enable_ilb_routing = false

# Optional echo VM for CUDN direct IP verification (icanhazip-clone). Requires
# enable_ilb_routing=true. VM needs Cloud NAT or public IP for podman image pull.
# enable_echo_client_vm = false
# echo_client_vm_zone = null
# echo_client_vm_port = 8080
# echo_client_vm_machine_type = "e2-micro"

# Enable PSC for private cluster
# enable_psc = false

# GCP authentication: use Application Default Credentials
# gcloud auth application-default login
